{
  "name": "civic-clarity-backend",
  "version": "1.0.0",
  "description": "Civic Clarity India — Election Education Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:run": "vitest run",
    "seed": "ts-node src/scripts/seedTopics.ts && ts-node src/scripts/seedTimeline.ts"
  },
  "dependencies": {
    "@google-cloud/vertexai": "1.1.0",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "^4.22.1",
    "firebase-admin": "^10.1.0",
    "helmet": "7.1.0",
    "nodemailer": "^6.9.13",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.14.2",
    "@typescript-eslint/eslint-plugin": "7.13.0",
    "@typescript-eslint/parser": "7.13.0",
    "eslint": "8.57.0",
    "fast-check": "3.19.0",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.5",
    "vitest": "^1.6.1"
  }
}
